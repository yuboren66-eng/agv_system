[Unit]
Description=AGV HTTP Topo API — FCGI endpoint serving /api/topo
Documentation=https://github.com/openclaw/ENavigate
After=agv-model-manager.service agv-log-daemon.service
Requires=agv-log-daemon.service

[Service]
Type=simple
User=www-data
Group=www-data
ExecStart=/opt/enavigate-master/build/src/http_service/Topo
Restart=always
RestartSec=3
StandardOutput=journal
StandardError=journal
SyslogIdentifier=agv-http-topo
LimitNOFILE=4096

[Install]
WantedBy=multi-user.target
